# Paper Agent 配置文件
# 复制此文件为 .env 并填写你的配置

# OpenAI API 配置（必填）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型配置（可选）
MODEL=gpt-4o-mini

# 目录配置（可选）
PAPERS_DIR=./papers
NOTES_DIR=./notes
DATABASE_DIR=./database

# 处理配置（可选）
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
